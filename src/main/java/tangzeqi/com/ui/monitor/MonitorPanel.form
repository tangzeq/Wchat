<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="tangzeqi.com.ui.monitor.MonitorPanel">
  <grid id="27dc6" binding="monitorPanel" layout-manager="GridLayoutManager" row-count="4" column-count="1" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
    <margin top="10" left="10" bottom="10" right="10"/>
    <constraints>
      <xy x="20" y="20" width="1000" height="700"/>
    </constraints>
    <properties>
      <minimumSize width="800" height="600"/>
      <preferredSize width="1000" height="700"/>
    </properties>
    <border type="empty">
      <font name="微软雅黑" size="14" style="1"/>
    </border>
    <children>
      <grid id="topControlPanel" binding="topControlPanel" layout-manager="GridLayoutManager" row-count="1" column-count="5" same-size-horizontally="false" same-size-vertically="false" hgap="10" vgap="-1">
        <margin top="5" left="5" bottom="5" right="5"/>
        <constraints>
          <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties/>
        <border type="empty"/>
        <children>
          <component id="projectInfoLabel" class="javax.swing.JLabel" binding="projectInfoLabel">
            <constraints>
              <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="2" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <font name="微软雅黑" size="14" style="1"/>
              <text value="当前工程: [未选择]"/>
            </properties>
          </component>
          <component id="refreshIntervalLabel" class="javax.swing.JLabel" binding="refreshIntervalLabel">
            <constraints>
              <grid row="0" column="1" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <font name="微软雅黑" size="12" style="0"/>
              <text value="刷新: 1s"/>
            </properties>
          </component>
          <component id="refreshButton" class="javax.swing.JButton" binding="refreshButton">
            <constraints>
              <grid row="0" column="2" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <font name="微软雅黑" size="12" style="0"/>
              <text value="🔄"/>
            </properties>
          </component>
          <component id="statusLabel" class="javax.swing.JLabel" binding="statusLabel">
            <constraints>
              <grid row="0" column="3" row-span="1" col-span="1" vsize-policy="0" hsize-policy="2" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <font name="微软雅黑" size="12" style="1"/>
              <text value="状态: 🟢 正常"/>
            </properties>
          </component>
          <component id="environmentInfoLabel" class="javax.swing.JLabel" binding="environmentInfoLabel">
            <constraints>
              <grid row="0" column="4" row-span="1" col-span="1" vsize-policy="0" hsize-policy="2" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <font name="微软雅黑" size="12" style="0"/>
              <text value="系统: Win11 | IP: 172.16.25.132"/>
            </properties>
          </component>
        </children>
      </grid>
      <grid id="metricsPanel" binding="metricsPanel" layout-manager="GridLayoutManager" row-count="1" column-count="1" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
        <margin top="0" left="0" bottom="0" right="0"/>
        <constraints>
          <grid row="1" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties/>
        <border type="empty"/>
        <children>
          <grid id="systemMetricsPanel" binding="systemMetricsPanel" layout-manager="GridLayoutManager" row-count="1" column-count="5" same-size-horizontally="true" same-size-vertically="false" hgap="10" vgap="-1">
            <margin top="0" left="0" bottom="0" right="0"/>
            <constraints>
              <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties/>
            <border type="etched" title="🖥️ 系统资源"/>
            <children>
              <component id="b32f8" class="javax.swing.JCheckBox" binding="systemCpuLabel">
                <constraints>
                  <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
                </constraints>
                <properties>
                  <enabled value="true"/>
                  <font name="微软雅黑" size="12" style="0"/>
                  <selected value="true"/>
                  <text value="🟢CPU: 0.00%"/>
                  <toolTipText value=""/>
                </properties>
              </component>
              <component id="fb394" class="javax.swing.JCheckBox" binding="systemMemoryLabel">
                <constraints>
                  <grid row="0" column="1" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
                </constraints>
                <properties>
                  <font name="微软雅黑" size="12" style="0"/>
                  <selected value="true"/>
                  <text value="🟢内存: 0.00%"/>
                </properties>
              </component>
              <component id="a75b9" class="javax.swing.JCheckBox" binding="systemDiskLabel">
                <constraints>
                  <grid row="0" column="2" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
                </constraints>
                <properties>
                  <font name="微软雅黑" size="12" style="0"/>
                  <selected value="true"/>
                  <text value="🟢磁盘: 0.00%"/>
                </properties>
              </component>
              <component id="b8af5" class="javax.swing.JCheckBox" binding="systemUploadLabel">
                <constraints>
                  <grid row="0" column="3" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
                </constraints>
                <properties>
                  <font name="微软雅黑" size="12" style="0"/>
                  <selected value="true"/>
                  <text value="📤上传: 0KB/s"/>
                </properties>
              </component>
              <component id="17d70" class="javax.swing.JCheckBox" binding="systemDownloadLabel">
                <constraints>
                  <grid row="0" column="4" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
                </constraints>
                <properties>
                  <font name="微软雅黑" size="12" style="0"/>
                  <selected value="true"/>
                  <text value="📥下载: 0KB/s"/>
                </properties>
              </component>
            </children>
          </grid>
        </children>
      </grid>
      <grid id="trendPanel" binding="trendPanel" layout-manager="GridLayoutManager" row-count="1" column-count="1" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
        <margin top="5" left="5" bottom="5" right="5"/>
        <constraints>
          <grid row="2" column="0" row-span="1" col-span="1" vsize-policy="3" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties/>
        <border type="etched" title="📈 性能趋势 (近5分钟)"/>
        <children>
          <component id="trendChart" class="javax.swing.JPanel" binding="trendChart" custom-create="true">
            <constraints>
              <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="3" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <opaque value="true"/>
            </properties>
          </component>
        </children>
      </grid>
      <grid id="alertPanel" binding="alertPanel" layout-manager="GridLayoutManager" row-count="1" column-count="1" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
        <margin top="5" left="5" bottom="5" right="5"/>
        <constraints>
          <grid row="3" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties/>
        <border type="etched" title="⚠️ 告警日志"/>
        <children>
          <component id="alertLabel" class="javax.swing.JLabel" binding="alertLabel">
            <constraints>
              <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <font name="微软雅黑" size="12" style="0"/>
              <text value="无告警"/>
            </properties>
          </component>
        </children>
      </grid>
    </children>
  </grid>
</form>
